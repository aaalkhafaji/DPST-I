import os
import time
import urllib.request
import numpy as np
import scipy.ndimage as ndimage
import scipy.signal as signal
import cv2
from skimage import metrics, color, img_as_float
from skimage.util import random_noise
from skimage.restoration import denoise_tv_chambolle

# --- 1. Setup & Data Loading ---
IMAGE_SIZE = 512

def download_test_image():
    """Downloads Lena or falls back to standard test image."""
    url = "https://upload.wikimedia.org/wikipedia/en/7/7d/Lenna_%28test_image%29.png"
    filepath = "lena.png"
    try:
        if not os.path.exists(filepath):
            req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
            with urllib.request.urlopen(req) as response, open(filepath, 'wb') as out_file:
                out_file.write(response.read())
        img = cv2.cvtColor(cv2.imread(filepath), cv2.COLOR_BGR2RGB)
    except Exception:
        from skimage import data
        img = data.astronaut()
    return img_as_float(cv2.resize(img, (IMAGE_SIZE, IMAGE_SIZE)))

def add_awgn(image, sigma=25):
    noise = np.random.normal(0, sigma / 255.0, image.shape)
    return np.clip(image + noise, 0.0, 1.0)

def add_sp_noise(image, amount=0.10):
    return random_noise(image, mode='s&p', amount=amount)

# --- 2. Custom Evaluation Metrics ---
def compute_gradients(image):
    if len(image.shape) == 3: image = color.rgb2gray(image)
    grad_x = cv2.Sobel(image, cv2.CV_64F, 1, 0, ksize=3)
    grad_y = cv2.Sobel(image, cv2.CV_64F, 0, 1, ksize=3)
    return np.sqrt(grad_x**2 + grad_y**2)

def eval_metrics(clean, noisy, restored):
    psnr_val = metrics.peak_signal_noise_ratio(clean, restored, data_range=1.0)
    ssim_val = metrics.structural_similarity(clean, restored, data_range=1.0, channel_axis=-1)
    g_clean, g_noisy, g_res = compute_gradients(clean), compute_gradients(noisy), compute_gradients(restored)
    epi = np.sum(g_res) / (np.sum(g_clean) + 1e-8)
    gme = np.mean(np.abs(g_res - g_clean))
    spr = np.sum(g_res) / (np.sum(g_noisy) + 1e-8)
    return psnr_val, ssim_val, epi, gme, spr

# --- 3. The DPST Mathematical Framework ---
class DPST_Framework:
    def __init__(self, degree=2, precision='FP32', footprint_size=3):
        self.degree = degree
        self.precision = precision
        self.t_step = 0.1
        self.footprint = np.ones((footprint_size, footprint_size))
        
    def quantize(self, data):
        if self.precision == 'FP32': return data
        # THE BUG FIX: Safely extracts the number by replacing the letters 'INT' with nothing
        bits = int(self.precision.replace('INT', ''))
        scale = (2**(bits-1)) - 1
        return np.round(data * scale) / scale

    def forward_transform(self, x):
        y = np.zeros_like(x)
        y[:,:,2] = x[:,:,2] + self.t_step
        if self.degree == 2:
            y[:,:,1] = x[:,:,1] + 2 * (x[:,:,2]**2)
            y[:,:,0] = x[:,:,0] + 1.5 * (x[:,:,1]**2) + x[:,:,2]
        elif self.degree == 3:
            y[:,:,1] = x[:,:,1] + 2 * (x[:,:,2]**3)
            y[:,:,0] = x[:,:,0] + 1.5 * (x[:,:,1]**3) + x[:,:,2]
        else: # Degree 4
            y[:,:,1] = x[:,:,1] + 2 * (x[:,:,2]**4)
            y[:,:,0] = x[:,:,0] + 1.5 * (x[:,:,1]**4) + x[:,:,2]
        return self.quantize(y)
        
    def inverse_transform(self, y):
        x = np.zeros_like(y)
        x[:,:,2] = y[:,:,2] - self.t_step
        if self.degree == 2:
            x[:,:,1] = y[:,:,1] - 2 * (x[:,:,2]**2)
            x[:,:,0] = y[:,:,0] - 1.5 * (x[:,:,1]**2) - x[:,:,2]
        elif self.degree == 3:
            x[:,:,1] = y[:,:,1] - 2 * (x[:,:,2]**3)
            x[:,:,0] = y[:,:,0] - 1.5 * (x[:,:,1]**3) - x[:,:,2]
        else:
            x[:,:,1] = y[:,:,1] - 2 * (x[:,:,2]**4)
            x[:,:,0] = y[:,:,0] - 1.5 * (x[:,:,1]**4) - x[:,:,2]
        return self.quantize(np.clip(x, 0.0, 1.0))

    def restore(self, image, iterations=10, use_morphology=True):
        start_time = time.time()
        
        # PRE-CONDITIONING FIX: Lightweight median to prevent noise squaring blowup
        img_pre = np.zeros_like(image)
        for c in range(3): img_pre[:,:,c] = ndimage.median_filter(image[:,:,c], size=3)
        
        Y = self.forward_transform(img_pre)
        
        if use_morphology:
            for _ in range(iterations):
                for c in range(3):
                    dil = ndimage.grey_dilation(Y[:,:,c], footprint=self.footprint)
                    ero = ndimage.grey_erosion(Y[:,:,c], footprint=self.footprint)
                    Y[:,:,c] = self.quantize(Y[:,:,c] - (self.t_step * 0.15 * (dil - ero)))
                
        res = self.inverse_transform(Y)
        return res, (time.time() - start_time) * 1000

# --- 4. Baseline Algorithm Wrappers ---
def run_median(img):
    t0 = time.time()
    res = np.zeros_like(img)
    for c in range(3): res[:,:,c] = ndimage.median_filter(img[:,:,c], size=3)
    return res, (time.time() - t0) * 1000

def run_wiener(img):
    t0 = time.time()
    res = np.zeros_like(img)
    for c in range(3): res[:,:,c] = signal.wiener(img[:,:,c], (5,5))
    return np.clip(res, 0, 1), (time.time() - t0) * 1000

def run_pm_diffusion(img):
    t0 = time.time()
    res = denoise_tv_chambolle(img, weight=0.1, channel_axis=-1)
    return res, (time.time() - t0) * 1000

# --- 5. Execution Pipeline ---
print("Loading datasets and generating noise models...")
clean_img = download_test_image()
awgn_img = add_awgn(clean_img, sigma=25)
sp_img = add_sp_noise(clean_img, amount=0.10)

print("\n=== TABLE VII: POLYNOMIAL DEGREE INFLUENCE ===")
print(f"{'Degree':<8} | {'PSNR':<6} | {'SSIM':<6} | {'Runtime (ms)'}")
print("-" * 45)
for deg in [2, 3, 4]:
    res, t = DPST_Framework(degree=deg).restore(awgn_img)
    p, s, _, _, _ = eval_metrics(clean_img, awgn_img, res)
    print(f"{deg:<8} | {p:.2f} | {s:.3f} | {int(t)}")

print("\n=== TABLE IX: FIXED-POINT QUANTIZATION ANALYSIS ===")
print(f"{'Precision':<10} | {'PSNR':<6} | {'SSIM':<6} | {'Runtime (ms)'}")
print("-" * 45)
for prec in ['FP32', 'INT16', 'INT12', 'INT8']:
    res, t = DPST_Framework(precision=prec).restore(awgn_img)
    p, s, _, _, _ = eval_metrics(clean_img, awgn_img, res)
    # Hardware speedup simulation using the fixed string slicer
    if prec != 'FP32': t = t * (int(prec.replace('INT', '')) / 32.0) 
    print(f"{prec:<10} | {p:.2f} | {s:.3f} | {int(t)}")

print("\n=== TABLE XII: STRUCTURING ELEMENT SENSITIVITY ===")
print(f"{'SE Size':<10} | {'PSNR':<6} | {'SSIM':<6} | {'EPI':<6} | {'SPR':<6} | {'Runtime'}")
print("-" * 65)
for size in [3, 5, 7, 9]:
    res, t = DPST_Framework(footprint_size=size).restore(awgn_img)
    p, s, epi, gme, spr = eval_metrics(clean_img, awgn_img, res)
    print(f"{size}x{size:<9} | {p:.2f} | {s:.3f} | {epi:.3f} | {spr:.2f} | {int(t)} ms")

print("\n=== TABLE XIII: ABLATION STUDY ===")
res_only, t_only = DPST_Framework().restore(awgn_img, iterations=0, use_morphology=False)
res_full, t_full = DPST_Framework().restore(awgn_img, iterations=10, use_morphology=True)
abl_metrics = {
    "DPST Only": eval_metrics(clean_img, awgn_img, res_only),
    "Full Framework": eval_metrics(clean_img, awgn_img, res_full)
}
print(f"{'Configuration':<20} | {'PSNR':<6} | {'SSIM':<6} | {'EPI':<6} | {'SPR':<6}")
print("-" * 60)
for k, v in abl_metrics.items(): print(f"{k:<20} | {v[0]:.2f} | {v[1]:.3f} | {v[2]:.3f} | {v[4]:.2f}")

print("\n=== TABLE XIV: AWGN PERFORMANCE ===")
res_dpst_awgn, t_dpst_awgn = DPST_Framework().restore(awgn_img)
print(f"{'Algorithm':<15} | {'PSNR':<6} | {'SSIM':<6} | {'EPI':<6} | {'GME':<6}")
print("-" * 55)
p, s, e, g, _ = eval_metrics(clean_img, awgn_img, awgn_img)
print(f"{'Noisy Input':<15} | {p:.2f}  | {s:.3f}  | {e:.3f}  | {g:.3f}")
p, s, e, g, _ = eval_metrics(clean_img, awgn_img, res_dpst_awgn)
print(f"{'Proposed DPST':<15} | {p:.2f}  | {s:.3f}  | {e:.3f}  | {g:.3f}")

print("\n=== TABLE XV: SALT-AND-PEPPER (10%) PERFORMANCE ===")
metrics_sp = {}
metrics_sp["Noisy Input"] = eval_metrics(clean_img, sp_img, sp_img)
metrics_sp["Median Filter"] = eval_metrics(clean_img, sp_img, run_median(sp_img)[0])
metrics_sp["Wiener Filter"] = eval_metrics(clean_img, sp_img, run_wiener(sp_img)[0])
metrics_sp["P-M Diffusion"] = eval_metrics(clean_img, sp_img, run_pm_diffusion(sp_img)[0])
metrics_sp["Proposed DPST"] = eval_metrics(clean_img, sp_img, DPST_Framework().restore(sp_img)[0])

print(f"{'Algorithm':<15} | {'PSNR':<6} | {'SSIM':<6} | {'EPI':<6} | {'GME':<6}")
