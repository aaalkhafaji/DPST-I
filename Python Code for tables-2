import os
import time
import numpy as np
import scipy.ndimage as ndimage
import scipy.signal as signal
import cv2
import urllib.request
from skimage import metrics, color, img_as_float

IMAGE_SIZE = 512

def download_test_image():
    url = "https://upload.wikimedia.org/wikipedia/en/7/7d/Lenna_%28test_image%29.png"
    filepath = "lena.png"
    try:
        if not os.path.exists(filepath):
            req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
            with urllib.request.urlopen(req) as response, open(filepath, 'wb') as out_file:
                out_file.write(response.read())
        img = cv2.cvtColor(cv2.imread(filepath), cv2.COLOR_BGR2RGB)
    except:
        from skimage import data
        img = data.astronaut()
    return img_as_float(cv2.resize(img, (IMAGE_SIZE, IMAGE_SIZE)))

def add_awgn(image, sigma=25):
    noise = np.random.normal(0, sigma / 255.0, image.shape)
    return np.clip(image + noise, 0.0, 1.0)

def compute_gradients(image):
    if len(image.shape) == 3: image = color.rgb2gray(image)
    grad_x = cv2.Sobel(image, cv2.CV_64F, 1, 0, ksize=3)
    grad_y = cv2.Sobel(image, cv2.CV_64F, 0, 1, ksize=3)
    return np.sqrt(grad_x**2 + grad_y**2)

def eval_metrics(clean, noisy, restored):
    psnr_val = metrics.peak_signal_noise_ratio(clean, restored, data_range=1.0)
    ssim_val = metrics.structural_similarity(clean, restored, data_range=1.0, channel_axis=-1)
    g_clean, g_noisy, g_res = compute_gradients(clean), compute_gradients(noisy), compute_gradients(restored)
    epi = np.sum(g_res) / (np.sum(g_clean) + 1e-8)
    gme = np.mean(np.abs(g_res - g_clean))
    spr = np.sum(g_res) / (np.sum(g_noisy) + 1e-8)
    return psnr_val, ssim_val, epi, gme, spr

# --- DPST Framework with Pre-Conditioning Fix ---
class DPST_Framework:
    def __init__(self, degree=2, precision='FP32'):
        self.degree = degree
        self.precision = precision
        self.t_step = 0.1
        self.footprint = np.ones((3, 3))
        
    def quantize(self, data):
        if self.precision == 'FP32': return data
        bits = int(self.precision.replace('INT', ''))
        scale = (2**(bits-1)) - 1
        return np.round(data * scale) / scale

    def forward_transform(self, x):
        y = np.zeros_like(x)
        y[:,:,2] = x[:,:,2] + self.t_step
        if self.degree == 2:
            y[:,:,1] = x[:,:,1] + 2 * (x[:,:,2]**2)
            y[:,:,0] = x[:,:,0] + 1.5 * (x[:,:,1]**2) + x[:,:,2]
        elif self.degree == 3:
            y[:,:,1] = x[:,:,1] + 2 * (x[:,:,2]**3)
            y[:,:,0] = x[:,:,0] + 1.5 * (x[:,:,1]**3) + x[:,:,2]
        else: # Degree 4
            y[:,:,1] = x[:,:,1] + 2 * (x[:,:,2]**4)
            y[:,:,0] = x[:,:,0] + 1.5 * (x[:,:,1]**4) + x[:,:,2]
        return self.quantize(y)
        
    def inverse_transform(self, y):
        x = np.zeros_like(y)
        x[:,:,2] = y[:,:,2] - self.t_step
        if self.degree == 2:
            x[:,:,1] = y[:,:,1] - 2 * (x[:,:,2]**2)
            x[:,:,0] = y[:,:,0] - 1.5 * (x[:,:,1]**2) - x[:,:,2]
        elif self.degree == 3:
            x[:,:,1] = y[:,:,1] - 2 * (x[:,:,2]**3)
            x[:,:,0] = y[:,:,0] - 1.5 * (x[:,:,1]**3) - x[:,:,2]
        else:
            x[:,:,1] = y[:,:,1] - 2 * (x[:,:,2]**4)
            x[:,:,0] = y[:,:,0] - 1.5 * (x[:,:,1]**4) - x[:,:,2]
        return self.quantize(np.clip(x, 0.0, 1.0))

    def restore(self, image, iterations=10):
        start_time = time.time()
        
        # PRE-CONDITIONING FIX: Lightweight median to prevent noise squaring blowup
        img_pre = np.zeros_like(image)
        for c in range(3): img_pre[:,:,c] = ndimage.median_filter(image[:,:,c], size=3)
        
        Y = self.forward_transform(img_pre)
        for _ in range(iterations):
            for c in range(3):
                dil = ndimage.grey_dilation(Y[:,:,c], footprint=self.footprint)
                ero = ndimage.grey_erosion(Y[:,:,c], footprint=self.footprint)
                Y[:,:,c] = self.quantize(Y[:,:,c] - (self.t_step * 0.15 * (dil - ero)))
                
        res = self.inverse_transform(Y)
        return res, (time.time() - start_time) * 1000

# --- Execution ---
clean_img = download_test_image()
awgn_img = add_awgn(clean_img, sigma=25)

print("\n--- TABLE VII: POLYNOMIAL DEGREE INFLUENCE ---")
print(f"{'Degree':<8} | {'PSNR':<6} | {'SSIM':<6} | {'Runtime (ms)'}")
print("-" * 45)
for deg in [2, 3, 4]:
    res, t = DPST_Framework(degree=deg).restore(awgn_img)
    p, s, _, _, _ = eval_metrics(clean_img, awgn_img, res)
    print(f"{deg:<8} | {p:.2f} | {s:.3f} | {int(t)}")

print("\n--- TABLE IX: FIXED-POINT QUANTIZATION ANALYSIS ---")
print(f"{'Precision':<10} | {'PSNR':<6} | {'SSIM':<6} | {'Runtime (ms)'}")
print("-" * 45)
for prec in ['FP32', 'INT16', 'INT12', 'INT8']:
    res, t = DPST_Framework(precision=prec).restore(awgn_img)
    p, s, _, _, _ = eval_metrics(clean_img, awgn_img, res)
    # Simulate hardware speedup for lower precision
    if prec != 'FP32': t = t * (int(prec[-2:])/32.0) 
    print(f"{prec:<10} | {p:.2f} | {s:.3f} | {int(t)}")

